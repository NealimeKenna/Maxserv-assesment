<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MaxServ B.V. assignment</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <h1>Products</h1>

        <div class="card">
            <div class="actions">
                <button id="import-btn">Import Products</button>
                <div id="status"></div>
            </div>

            <form method="get" action="/" class="filter-form">
                <div class="filter-group">
                    <label for="brand">Brand</label>
                    <select name="filters[brand]" id="brand">
                        <option value="">All Brands</option>
                        {% for b in brands %}
                            <option value="{{ b }}" {% if b == filters.brand|default('') %}selected{% endif %}>{{ b }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-group">
                    <label for="category">Category</label>
                    <select name="filters[category]" id="category">
                        <option value="">All Categories</option>
                        {% for c in categories %}
                            <option value="{{ c }}" {% if c == filters.category|default('') %}selected{% endif %}>{{ c }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="button-group">
                    <button type="submit">Filter</button>
                    <a href="/" class="btn btn-clear">Clear</a>
                </div>
            </form>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th class="no-sort">Thumbnail</th>
                        <th>
                            <a href="/?{{ {filters: filters, sort: {field: 'title', order: (sort.field == 'title' and sort.order == 'asc') ? 'desc' : 'asc'}} | url_encode }}">
                                Title
                                {% if sort.field == 'title' %}
                                    <span class="sort-icon">{{ sort.order == 'asc' ? '↑' : '↓' }}</span>
                                {% endif %}
                            </a>
                        </th>
                        <th>
                            <a href="/?{{ {filters: filters, sort: {field: 'price', order: (sort.field == 'price' and sort.order == 'asc') ? 'desc' : 'asc'}} | url_encode }}">
                                Price
                                {% if sort.field == 'price' %}
                                    <span class="sort-icon">{{ sort.order == 'asc' ? '↑' : '↓' }}</span>
                                {% endif %}
                            </a>
                        </th>
                        <th>
                            <a href="/?{{ {filters: filters, sort: {field: 'brand', order: (sort.field == 'brand' and sort.order == 'asc') ? 'desc' : 'asc'}} | url_encode }}">
                                Brand
                                {% if sort.field == 'brand' %}
                                    <span class="sort-icon">{{ sort.order == 'asc' ? '↑' : '↓' }}</span>
                                {% endif %}
                            </a>
                        </th>
                        <th>
                            <a href="/?{{ {filters: filters, sort: {field: 'category', order: (sort.field == 'category' and sort.order == 'asc') ? 'desc' : 'asc'}} | url_encode }}">
                                Category
                                {% if sort.field == 'category' %}
                                    <span class="sort-icon">{{ sort.order == 'asc' ? '↑' : '↓' }}</span>
                                {% endif %}
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {% for product in products %}
                        <tr>
                            <td><img src="{{ product.thumbnail }}" alt="{{ product.title }}" class="thumbnail"></td>
                            <td>{{ product.title }}</td>
                            <td>
                                <span class="price-original">€{{ product.price|number_format(2, ',', '.') }}</span>
                                {% set discounted_price = product.price * (1 - product.discount_percentage / 100) %}
                                <span class="price-discounted">({{ '€' ~ discounted_price|number_format(2, ',', '.') }})</span>
                            </td>
                            <td>{{ product.brand }}</td>
                            <td>{{ product.category }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="empty-state">No products were found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        document.getElementById('import-btn').addEventListener('click', function() {
            const status = document.getElementById('status');
            status.innerText = 'Importing...';
            this.disabled = true;

            fetch('/products/import')
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        status.innerText = 'Import successful: ' + data.message;
                        setTimeout(() => location.reload(), 2000);
                    } else {
                        status.innerText = 'Error: ' + data.message;
                        this.disabled = false;
                    }
                })
                .catch(error => {
                    status.innerText = 'Error: ' + error;
                    this.disabled = false;
                });
        });
    </script>
</body>
</html>
